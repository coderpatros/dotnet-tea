@page
@model CoderPatros.Tea.Web.Pages.DiscoverModel
@{
    ViewData["Title"] = "Discover TEI";
}

<h2>Discover TEI</h2>
@if (Model.Tei is not null)
{
    <p>TEI: <code>@Model.Tei</code></p>
}

<partial name="_ErrorPartial" model="Model.ErrorMessage" />

@if (Model.Results is not null)
{
    @if (Model.Results.Count == 0)
    {
        <div class="alert alert-warning">No TEA servers found for this TEI.</div>
    }
    else
    {
        @foreach (var result in Model.Results)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Product Release</h5>
                    <p class="tea-uuid">
                        <a asp-page="/Releases/ProductRelease" asp-route-uuid="@result.ProductReleaseUuid">@result.ProductReleaseUuid</a>
                    </p>

                    <h6>Servers</h6>
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Root URL</th>
                                <th>Versions</th>
                                <th>Priority</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var server in result.Servers)
                            {
                                var version = server.Versions.FirstOrDefault() ?? "0.3.0-beta.2";
                                var serverUrl = $"{server.RootUrl.TrimEnd('/')}/v{version}";
                                <tr>
                                    <td><code>@server.RootUrl</code></td>
                                    <td>@string.Join(", ", server.Versions)</td>
                                    <td>@server.Priority</td>
                                    <td>
                                        <form method="post" asp-page="/Index" asp-page-handler="Settings" class="d-inline">
                                            <input type="hidden" name="BaseUrl" value="@serverUrl" />
                                            <input type="hidden" name="Token" value="@ViewContext.HttpContext.Session.GetString("Tea:Token")" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Use This Server</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}
